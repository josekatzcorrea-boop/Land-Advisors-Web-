# Copia este archivo a .env y completa los valores.
# Nunca subas .env al repositorio.

# App de Meta Developers (developers.facebook.com)
META_APP_ID=
META_APP_SECRET=

# Token de acceso de la Página de Facebook vinculada a Instagram.
# Permisos actuales (2025+): instagram_business_basic, instagram_business_content_publish,
# pages_show_list, pages_read_engagement
META_PAGE_ACCESS_TOKEN=

# ID numérico de la cuenta de Instagram Business/Creator (no el @usuario)
META_IG_USER_ID=

# Opcional: ID de la Página de Facebook (para verificación)
META_PAGE_ID=

# Versión de Graph API (actualizar según documentación Meta)
META_GRAPH_VERSION=v22.0
